# SalitAI.orbit Backend Configuration
# Copy this file to .env and fill in your values

# ===========================
# REQUIRED
# ===========================

# Gemini API Key (Get from: https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# ===========================
# OPTIONAL (with defaults)
# ===========================

# Server Configuration
PORT=8082
NODE_ENV=development

# Gemini Models (leave empty to use automatic fallback)
# Available models: gemini-1.5-flash, gemini-1.5-flash-8b, gemini-1.5-pro
GEMINI_MODEL_STT=
GEMINI_MODEL_MINUTES=

# Upload Configuration
MAX_UPLOAD_MB=200

# CORS Configuration (comma-separated list of allowed origins)
ALLOWED_ORIGINS=

# Email Configuration (for contact form)
SMTP_SERVICE=gmail
SMTP_USER=
SMTP_PASS=
CONTACT_TO_EMAIL=

# ===========================
# NOTES
# ===========================

# 1. GEMINI_API_KEY is REQUIRED - get it from https://aistudio.google.com/apikey
# 2. If GEMINI_MODEL_STT or GEMINI_MODEL_MINUTES are empty, the system will automatically
#    try multiple models in order: gemini-1.5-flash, gemini-1.5-flash-8b, gemini-1.5-pro
# 3. ALLOWED_ORIGINS: Add your production domain (e.g., https://yourdomain.com)
# 4. Email settings are optional - only needed if you want the contact form to work
# 5. MAX_UPLOAD_MB: Maximum file size in megabytes (default: 200MB)
